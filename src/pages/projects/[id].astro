---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FadeIn from '../../components/FadeIn';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;

const currentIndex = projects.findIndex((p) => p.id === project.id);
const nextProject = projects[(currentIndex + 1) % projects.length];
---

<BaseLayout title={project.title} description={project.description} navVariant="dark">
  <!-- Hero -->
  <section class="relative h-[75vh] flex items-end pb-16 md:pb-24 overflow-hidden">
    <img src={project.images[0]} alt={project.title} class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-dark/90 via-dark/30 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
      <FadeIn client:load>
        <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">{project.category}</p>
        <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl text-parchment tracking-tight max-w-4xl">
          {project.title}
        </h1>
      </FadeIn>
    </div>
  </section>

  <!-- Project Details — Asymmetric -->
  <section class="py-20 md:py-32 bg-parchment">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-7">
          <FadeIn client:load>
            <p class="text-muted text-lg leading-relaxed mb-16 max-w-xl">
              {project.description}
            </p>
          </FadeIn>

          <div class="space-y-6">
            {project.images.map((img: string, i: number) => (
              <FadeIn client:load delay={i * 0.08}>
                <img
                  src={img}
                  alt={`${project.title} - Image ${i + 1}`}
                  loading="lazy"
                  class="w-full h-auto object-cover"
                />
              </FadeIn>
            ))}
          </div>
        </div>

        <div class="lg:col-span-4 lg:col-start-9">
          <FadeIn client:load delay={0.15}>
            <div class="lg:sticky lg:top-32 space-y-8">
              <div>
                <h4 class="font-body text-[11px] tracking-[0.2em] text-accent uppercase mb-2">Category</h4>
                <p class="text-dark text-sm">{project.category}</p>
              </div>
              <div>
                <h4 class="font-body text-[11px] tracking-[0.2em] text-accent uppercase mb-2">Location</h4>
                <p class="text-dark text-sm">{project.location}</p>
              </div>
              <div class="pt-6 border-t border-border">
                <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-parchment font-body text-sm rounded-full hover:opacity-90 transition-opacity">
                  Start a Similar Project <span>&rarr;</span>
                </a>
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </div>
  </section>

  <!-- Next Project -->
  <section class="py-24 md:py-32 bg-dark">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="font-body text-[11px] tracking-[0.3em] text-parchment/20 uppercase mb-6">Next Project</p>
      <a href={`/projects/${nextProject.id}`} class="group inline-block">
        <h2 class="font-heading text-4xl md:text-6xl text-parchment tracking-tight group-hover:text-accent transition-colors">
          {nextProject.title}
        </h2>
        <p class="text-parchment/30 text-sm mt-4 group-hover:text-parchment/50 transition-colors">
          {nextProject.category} — {nextProject.location}
        </p>
      </a>
    </div>
  </section>
</BaseLayout>
