---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FadeIn from '../../components/FadeIn';
import TextReveal from '../../components/TextReveal';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;

// Find next project for navigation
const currentIndex = projects.findIndex((p) => p.id === project.id);
const nextProject = projects[(currentIndex + 1) % projects.length];
---

<BaseLayout title={project.title} description={project.description} navVariant="dark">
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-end pb-16 md:pb-24 bg-charcoal overflow-hidden">
    <img src={project.images[0]} alt={project.title} class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/95 via-ink/40 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
      <FadeIn client:load direction="none">
        <p class="font-body text-[11px] tracking-[0.3em] text-brass uppercase mb-4">{project.category}</p>
      </FadeIn>
      <TextReveal client:load delay={0.2}>
        <h1 class="font-heading text-4xl md:text-6xl lg:text-7xl text-cream tracking-tight max-w-4xl">
          {project.title}
        </h1>
      </TextReveal>
    </div>
  </section>

  <!-- Project Details -->
  <section class="py-16 md:py-24 bg-warm-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <!-- Sidebar -->
        <div class="lg:col-span-3 order-2 lg:order-1">
          <FadeIn client:load direction="left">
            <div class="space-y-8 lg:sticky lg:top-32">
              <div>
                <h3 class="font-body text-[11px] font-medium tracking-[0.2em] text-brass uppercase mb-2">Category</h3>
                <p class="text-text-primary">{project.category}</p>
              </div>
              <div>
                <h3 class="font-body text-[11px] font-medium tracking-[0.2em] text-brass uppercase mb-2">Location</h3>
                <p class="text-text-primary">{project.location}</p>
              </div>
              <div class="pt-4 border-t border-border">
                <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-brass text-warm-white font-body text-sm rounded-full hover:bg-brass-light transition-colors">
                  Start a Similar Project <span>&rarr;</span>
                </a>
              </div>
            </div>
          </FadeIn>
        </div>

        <!-- Content -->
        <div class="lg:col-span-9 order-1 lg:order-2">
          <FadeIn client:load direction="up">
            <p class="text-text-secondary text-lg leading-relaxed mb-12 max-w-2xl">
              {project.description}
            </p>
          </FadeIn>

          <!-- Image Gallery -->
          <div class="space-y-5">
            {project.images.map((img: string, i: number) => (
              <FadeIn client:load delay={i * 0.1} direction="up">
                <div class="overflow-hidden rounded-2xl">
                  <img
                    src={img}
                    alt={`${project.title} - Image ${i + 1}`}
                    loading="lazy"
                    class="w-full h-auto object-cover hover:scale-[1.02] transition-transform duration-700"
                  />
                </div>
              </FadeIn>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Next Project -->
  <section class="py-24 md:py-32 gradient-dark noise-overlay">
    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <p class="font-body text-[11px] tracking-[0.3em] text-cream/30 uppercase mb-6">Next Project</p>
      <a href={`/projects/${nextProject.id}`} class="group inline-block">
        <h2 class="font-heading text-4xl md:text-6xl text-cream tracking-tight group-hover:text-brass transition-colors">
          {nextProject.title}
        </h2>
        <p class="font-body text-sm text-cream/40 mt-4 group-hover:text-cream/60 transition-colors">
          {nextProject.category} — {nextProject.location}
        </p>
      </a>
    </div>
  </section>
</BaseLayout>
