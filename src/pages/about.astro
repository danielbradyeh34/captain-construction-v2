---
import BaseLayout from '../layouts/BaseLayout.astro';
import FadeIn from '../components/FadeIn';
---

<BaseLayout title="About" description="Learn about Captain Construction Co. — Geelong's premium residential builder." navVariant="dark">
  <!-- Hero -->
  <section class="relative bg-dark pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
    <img src="/images/heroes/hero-modern-dark.jpg" alt="" loading="eager" class="absolute inset-0 w-full h-full object-cover opacity-30" />
    <div class="absolute inset-0 bg-gradient-to-t from-dark/90 via-dark/50 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="max-w-2xl">
        <FadeIn client:load>
          <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">About Us</p>
          <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl text-parchment tracking-tight">
            Built on trust
          </h1>
          <p class="text-parchment/45 text-lg max-w-lg mt-6">
            Quality driven. Built on a reputation of craftsmanship and trust.
          </p>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- Story — Asymmetric layout -->
  <section class="py-24 md:py-36 bg-parchment">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <FadeIn client:load>
            <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">Our Story</p>
            <h2 class="font-heading text-4xl md:text-5xl text-dark tracking-tight mb-8">Why Captain?</h2>
            <div class="space-y-6 text-muted leading-relaxed">
              <p>
                Captain Construction Co. was founded with a simple belief: every home deserves to be built by someone who genuinely cares about the outcome. Not just getting the job done — but getting it right.
              </p>
              <p>
                Based in Geelong, we're a fully licensed builder specialising in residential construction that demands attention to detail. From ground-up new builds to extensions that transform how families live.
              </p>
              <p>
                The anchor in our name represents stability, strength, and a foundation you can rely on. That's what we build.
              </p>
            </div>
          </FadeIn>
        </div>
        <div>
          <FadeIn client:load delay={0.15}>
            <img src="/images/projects/new-builds/glass-staircase-polished-floor-01.jpg" alt="Glass staircase with polished concrete floor" loading="lazy" class="aspect-[4/5] w-full object-cover" />
          </FadeIn>
        </div>
      </div>
    </div>
  </section>

  <!-- What Sets Us Apart -->
  <section class="py-24 md:py-36 bg-stone">
    <div class="max-w-5xl mx-auto px-6">
      <FadeIn client:load>
        <div class="text-center mb-16">
          <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">The Difference</p>
          <h2 class="font-heading text-4xl md:text-6xl text-dark tracking-tight">What sets us apart</h2>
        </div>
      </FadeIn>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <FadeIn client:load delay={0}>
          <div class="p-8 md:p-10 bg-dark h-full">
            <h3 class="font-body text-xs font-medium tracking-[0.15em] text-accent uppercase mb-4">Not a Volume Builder</h3>
            <p class="text-parchment/60 text-sm leading-relaxed">
              We take on a limited number of projects at any given time so that every build gets the focus it deserves. That means direct communication with Cal, not a project manager you've never met.
            </p>
          </div>
        </FadeIn>
        <FadeIn client:load delay={0.1}>
          <div class="p-8 md:p-10 bg-parchment h-full">
            <h3 class="font-body text-xs font-medium tracking-[0.15em] text-accent uppercase mb-4">Timber Craftsmanship</h3>
            <p class="text-muted text-sm leading-relaxed">
              Natural timber cladding, hardwood decking, bespoke joinery, and finishing touches that elevate a build from good to exceptional. It's the work most people don't notice until they see it done properly.
            </p>
          </div>
        </FadeIn>
        <FadeIn client:load delay={0.2}>
          <div class="p-8 md:p-10 bg-dark h-full">
            <h3 class="font-body text-xs font-medium tracking-[0.15em] text-accent uppercase mb-4">15+ Years Licensed</h3>
            <p class="text-parchment/60 text-sm leading-relaxed">
              Fully licensed and insured with over fifteen years of building across Geelong and the greater region. We stand behind every project with a comprehensive structural warranty.
            </p>
          </div>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-24 md:py-36 bg-dark">
    <div class="max-w-7xl mx-auto px-6">
      <FadeIn client:load>
        <div class="text-center mb-16">
          <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">Where We Build</p>
          <h2 class="font-heading text-4xl md:text-6xl text-parchment tracking-tight">Service Areas</h2>
        </div>
      </FadeIn>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        {['Geelong', 'Bellarine Peninsula', 'Surf Coast', 'Golden Plains', 'Barwon Heads', 'Ocean Grove', 'Torquay', 'Greater Region'].map((area, i) => (
          <FadeIn client:load delay={i * 0.05}>
            <div class="text-center py-4 px-2 border border-parchment/8 hover:border-accent/30 transition-colors">
              <p class="font-body text-sm text-parchment/70">{area}</p>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-24 md:py-36 bg-parchment">
    <div class="max-w-5xl mx-auto px-6">
      <FadeIn client:load>
        <div class="text-center mb-16">
          <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">Our Values</p>
          <h2 class="font-heading text-4xl md:text-6xl text-dark tracking-tight">How we work</h2>
        </div>
      </FadeIn>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { num: '01', title: 'Quality First', desc: "We don't cut corners. Every material is selected for durability and every joint is built to last." },
          { num: '02', title: 'Clear Communication', desc: "You'll always know where your project stands. Regular updates, honest timelines, and no surprises." },
          { num: '03', title: 'Personal Touch', desc: "You deal directly with Cal — the person who built the business and leads every project." },
        ].map((item, i) => (
          <FadeIn client:load delay={i * 0.1}>
            <div class="text-center p-8 md:p-10 bg-stone">
              <span class="font-heading text-4xl text-accent/25 block mb-4">{item.num}</span>
              <h3 class="font-body text-xs font-medium tracking-[0.15em] uppercase mb-4 text-dark">{item.title}</h3>
              <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 md:py-44 bg-dark border-t border-parchment/5">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <h2 class="font-heading text-4xl md:text-7xl text-parchment tracking-tight mb-6">
          Let's talk about<br /><em class="text-accent">your project</em>
        </h2>
        <p class="text-parchment/40 text-lg mb-10 max-w-xl mx-auto">
          Ready to build something exceptional? Get in touch for a no-obligation consultation.
        </p>
        <a href="/contact" class="inline-block px-10 py-4 bg-accent text-parchment font-body text-sm tracking-wide rounded-full hover:opacity-90 transition-opacity">
          Contact Us
        </a>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
