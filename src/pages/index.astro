---
import BaseLayout from '../layouts/BaseLayout.astro';
import FadeIn from '../components/FadeIn';
import ProjectGrid from '../components/ProjectGrid';
import TestimonialCarousel from '../components/TestimonialCarousel';
import { services } from '../data/services';
---

<BaseLayout title="Home" navVariant="dark">
  <!-- Hero Section — Full-bleed editorial photography -->
  <section class="relative min-h-screen flex items-end pb-20 md:pb-28 bg-charcoal overflow-hidden">
    <!-- Hero background image -->
    <img
      src="/images/projects/new-builds/modern-timber-dark-render-01.jpg"
      alt="Modern timber and render home by Captain Construction"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-charcoal/90 via-charcoal/30 to-transparent"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
      <div class="max-w-3xl">
        <FadeIn client:load delay={0.3} direction="none">
          <p class="font-heading text-xs md:text-sm tracking-[0.4em] text-brass uppercase mb-6">
            Geelong & Greater Region
          </p>
        </FadeIn>

        <FadeIn client:load delay={0.5} direction="up">
          <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl tracking-[0.05em] text-warm-white font-light leading-[0.95] mb-8">
            Building With<br />
            Purpose & Pride
          </h1>
        </FadeIn>

        <FadeIn client:load delay={0.7} direction="up">
          <p class="text-cream/60 text-lg md:text-xl max-w-xl leading-relaxed mb-10">
            Premium residential construction, extensions, and bespoke outdoor living. Craftsmanship that speaks for itself.
          </p>
        </FadeIn>

        <FadeIn client:load delay={0.9} direction="up">
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/projects"
              class="px-10 py-4 bg-brass text-warm-white font-heading text-sm tracking-[0.2em] uppercase hover:bg-brass-light transition-colors duration-300"
            >
              View Our Work
            </a>
            <a
              href="/contact"
              class="px-10 py-4 border border-cream/30 text-cream font-heading text-sm tracking-[0.2em] uppercase hover:border-brass hover:text-brass transition-colors duration-300"
            >
              Get a Quote
            </a>
          </div>
        </FadeIn>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 right-8 md:right-12">
      <div class="flex flex-col items-center gap-3 animate-bounce">
        <span class="font-heading text-[10px] tracking-[0.3em] text-cream/40 uppercase" style="writing-mode: vertical-lr;">Scroll</span>
        <div class="w-px h-12 bg-gradient-to-b from-brass/50 to-transparent"></div>
      </div>
    </div>
  </section>

  <!-- Services Section — Light, editorial -->
  <section class="py-24 md:py-32 bg-warm-white">
    <div class="max-w-7xl mx-auto px-6">
      <FadeIn client:load>
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16">
          <div>
            <p class="font-heading text-xs tracking-[0.4em] text-brass uppercase mb-4">What We Do</p>
            <h2 class="font-heading text-3xl md:text-5xl tracking-[0.05em] text-charcoal font-light">Our Services</h2>
          </div>
          <p class="text-text-secondary text-base max-w-md mt-4 md:mt-0">
            Every project is approached with the same standard of precision, from concept through to completion.
          </p>
        </div>
      </FadeIn>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-border">
        {services.map((service, i) => (
          <FadeIn client:load delay={i * 0.1} direction="up">
            <div class="group p-8 md:p-10 bg-warm-white hover:bg-sage/10 transition-all duration-500 h-full">
              <span class="font-heading text-3xl text-brass/30 block mb-6">0{i + 1}</span>
              <h3 class="font-heading text-sm tracking-[0.2em] text-charcoal uppercase mb-4 transition-colors">
                {service.title}
              </h3>
              <p class="text-text-secondary text-sm leading-relaxed">
                {service.description}
              </p>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Projects — Dark section, editorial grid -->
  <section class="py-24 md:py-32 bg-charcoal">
    <div class="max-w-7xl mx-auto px-6">
      <FadeIn client:load>
        <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-16">
          <div>
            <p class="font-heading text-xs tracking-[0.4em] text-brass uppercase mb-4">Our Work</p>
            <h2 class="font-heading text-3xl md:text-5xl tracking-[0.05em] text-cream font-light">Featured Projects</h2>
          </div>
          <a
            href="/projects"
            class="text-cream/50 font-heading text-xs tracking-[0.2em] uppercase hover:text-brass transition-colors mt-4 md:mt-0"
          >
            View All &rarr;
          </a>
        </div>
      </FadeIn>

      <FadeIn client:load delay={0.2}>
        <ProjectGrid client:load featuredOnly={true} />
      </FadeIn>
    </div>
  </section>

  <!-- Testimonials — Sage background, editorial -->
  <section class="py-24 md:py-32 bg-stone-light">
    <div class="max-w-7xl mx-auto px-6">
      <FadeIn client:load>
        <div class="text-center mb-4">
          <p class="font-heading text-xs tracking-[0.4em] text-brass uppercase mb-4">Testimonials</p>
          <h2 class="font-heading text-3xl md:text-5xl tracking-[0.05em] text-charcoal font-light mb-12">What Our Clients Say</h2>
        </div>
      </FadeIn>

      <FadeIn client:load delay={0.2}>
        <TestimonialCarousel client:load variant="light" />
      </FadeIn>
    </div>
  </section>

  <!-- Process Teaser -->
  <section class="py-24 md:py-32 bg-warm-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <p class="font-heading text-xs tracking-[0.4em] text-brass uppercase mb-4">How We Work</p>
        <h2 class="font-heading text-3xl md:text-5xl tracking-[0.05em] text-charcoal font-light mb-6">From Vision to Reality</h2>
        <p class="text-text-secondary text-lg leading-relaxed max-w-2xl mx-auto mb-10">
          Every great build starts with a conversation. Our five-step process is designed to make your building experience transparent, stress-free, and exactly what you envisioned.
        </p>
        <a
          href="/process"
          class="inline-block px-10 py-4 bg-charcoal text-cream font-heading text-sm tracking-[0.2em] uppercase hover:bg-brass transition-colors duration-300"
        >
          Our Process
        </a>
      </FadeIn>
    </div>
  </section>

  <!-- CTA Banner — Brass accent -->
  <section class="py-24 md:py-32 bg-charcoal">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <h2 class="font-heading text-3xl md:text-6xl tracking-[0.05em] text-cream font-light mb-6">
          Ready to Build?
        </h2>
        <p class="text-cream/50 text-lg mb-10 max-w-xl mx-auto">
          Whether it's a new home, an extension, or the deck you've always wanted — let's talk about making it happen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="px-10 py-4 bg-brass text-warm-white font-heading text-sm tracking-[0.2em] uppercase hover:bg-brass-light transition-colors duration-300"
          >
            Start Your Project
          </a>
          <a
            href="tel:0419400734"
            class="px-10 py-4 border border-cream/20 text-cream font-heading text-sm tracking-[0.2em] uppercase hover:border-brass hover:text-brass transition-colors duration-300"
          >
            Call 0419 400 734
          </a>
        </div>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
