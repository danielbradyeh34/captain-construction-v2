---
import BaseLayout from '../layouts/BaseLayout.astro';
import FadeIn from '../components/FadeIn';
import TestimonialCarousel from '../components/TestimonialCarousel';
import { projects } from '../data/projects';
import { testimonials } from '../data/testimonials';

const featured = projects.filter((p) => p.featured).slice(0, 4);
---

<BaseLayout title="Home" navVariant="dark">
  <!-- Hero — Full-bleed video, minimal text -->
  <section class="relative h-screen flex items-end pb-20 md:pb-28 overflow-hidden">
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-t from-dark/90 via-dark/30 to-dark/10"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 w-full">
      <FadeIn client:load delay={0.3}>
        <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-6">
          Geelong & Greater Region
        </p>
      </FadeIn>
      <FadeIn client:load delay={0.5}>
        <h1 class="font-heading text-[2.75rem] md:text-[5rem] lg:text-[6.5rem] text-parchment leading-[0.95] tracking-tight max-w-4xl">
          Building with<br /><em>purpose & pride</em>
        </h1>
      </FadeIn>
      <FadeIn client:load delay={0.8}>
        <p class="text-parchment/50 text-base md:text-lg max-w-md mt-8 leading-relaxed">
          Premium residential construction, extensions, and bespoke outdoor living.
        </p>
      </FadeIn>
      <FadeIn client:load delay={1.0}>
        <div class="flex gap-4 mt-10">
          <a href="/projects" class="px-8 py-3.5 bg-accent text-parchment font-body text-sm tracking-wide rounded-full hover:opacity-90 transition-opacity">
            View Our Work
          </a>
          <a href="/contact" class="px-8 py-3.5 border border-parchment/20 text-parchment font-body text-sm tracking-wide rounded-full hover:border-accent hover:text-accent transition-colors">
            Start a Project
          </a>
        </div>
      </FadeIn>
    </div>
  </section>

  <!-- Selected Projects — Large, image-dominant, asymmetric -->
  <section class="py-24 md:py-40 bg-parchment">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-12 mb-20">
        <div class="lg:col-span-7">
          <FadeIn client:load>
            <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">Selected Work</p>
            <h2 class="font-heading text-4xl md:text-6xl text-dark tracking-tight">
              Projects that speak<br />for themselves
            </h2>
          </FadeIn>
        </div>
        <div class="lg:col-span-4 lg:col-start-9 flex items-end">
          <FadeIn client:load delay={0.15}>
            <a href="/projects" class="text-muted font-body text-sm hover:text-accent transition-colors flex items-center gap-2">
              View all projects <span>&rarr;</span>
            </a>
          </FadeIn>
        </div>
      </div>

      <!-- Project 1 — Full width hero -->
      {featured[0] && (
        <FadeIn client:load>
          <a href={`/projects/${featured[0].id}`} class="group block mb-8">
            <div class="relative aspect-[16/9] overflow-hidden">
              <img
                src={featured[0].images[0]}
                alt={featured[0].title}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
              />
            </div>
            <div class="mt-5 flex flex-col md:flex-row md:items-baseline md:justify-between gap-2">
              <h3 class="font-heading text-2xl md:text-3xl text-dark tracking-tight">{featured[0].title}</h3>
              <p class="text-muted text-sm">{featured[0].category} — {featured[0].location}</p>
            </div>
          </a>
        </FadeIn>
      )}

      <!-- Projects 2 & 3 — Asymmetric 7/5 grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-8">
        {featured[1] && (
          <div class="md:col-span-7">
            <FadeIn client:load delay={0.1}>
              <a href={`/projects/${featured[1].id}`} class="group block">
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img
                    src={featured[1].images[0]}
                    alt={featured[1].title}
                    loading="lazy"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                  />
                </div>
                <div class="mt-5 flex flex-col md:flex-row md:items-baseline md:justify-between gap-2">
                  <h3 class="font-heading text-xl md:text-2xl text-dark tracking-tight">{featured[1].title}</h3>
                  <p class="text-muted text-sm">{featured[1].location}</p>
                </div>
              </a>
            </FadeIn>
          </div>
        )}
        {featured[2] && (
          <div class="md:col-span-5">
            <FadeIn client:load delay={0.2}>
              <a href={`/projects/${featured[2].id}`} class="group block">
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img
                    src={featured[2].images[0]}
                    alt={featured[2].title}
                    loading="lazy"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
                  />
                </div>
                <div class="mt-5 flex flex-col md:flex-row md:items-baseline md:justify-between gap-2">
                  <h3 class="font-heading text-xl md:text-2xl text-dark tracking-tight">{featured[2].title}</h3>
                  <p class="text-muted text-sm">{featured[2].location}</p>
                </div>
              </a>
            </FadeIn>
          </div>
        )}
      </div>

      <!-- Project 4 — if exists -->
      {featured[3] && (
        <FadeIn client:load delay={0.1}>
          <a href={`/projects/${featured[3].id}`} class="group block">
            <div class="relative aspect-[21/9] overflow-hidden">
              <img
                src={featured[3].images[0]}
                alt={featured[3].title}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
              />
            </div>
            <div class="mt-5 flex flex-col md:flex-row md:items-baseline md:justify-between gap-2">
              <h3 class="font-heading text-2xl md:text-3xl text-dark tracking-tight">{featured[3].title}</h3>
              <p class="text-muted text-sm">{featured[3].category} — {featured[3].location}</p>
            </div>
          </a>
        </FadeIn>
      )}
    </div>
  </section>

  <!-- Philosophy — Brief, asymmetric -->
  <section class="py-24 md:py-40 bg-dark">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-5">
          <FadeIn client:load>
            <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">About</p>
            <h2 class="font-heading text-4xl md:text-5xl text-parchment tracking-tight">
              Owner-managed,<br />start to finish
            </h2>
          </FadeIn>
        </div>
        <div class="lg:col-span-6 lg:col-start-7 flex items-center">
          <FadeIn client:load delay={0.15}>
            <div>
              <p class="text-parchment/60 text-lg leading-relaxed mb-8">
                Every Captain Construction project is personally managed by Cal. No project managers in between, no miscommunication, no compromises. Fifteen years of building homes across Geelong and the greater region — the same standard of precision on every job.
              </p>
              <a href="/about" class="text-accent font-body text-sm hover:opacity-80 transition-opacity flex items-center gap-2">
                More about us <span>&rarr;</span>
              </a>
            </div>
          </FadeIn>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials — Rotating carousel -->
  <section class="py-24 md:py-40 bg-stone">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <TestimonialCarousel client:load testimonials={testimonials} />
    </div>
  </section>

  <!-- CTA — Clean, confident -->
  <section class="py-28 md:py-44 bg-dark">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <h2 class="font-heading text-4xl md:text-6xl lg:text-7xl text-parchment tracking-tight mb-8">
          Ready to build?
        </h2>
        <p class="text-parchment/40 text-base md:text-lg mb-12 max-w-xl mx-auto">
          Whether it's a new home, extension, or outdoor space — let's talk about making it happen.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="px-10 py-4 bg-accent text-parchment font-body text-sm tracking-wide rounded-full hover:opacity-90 transition-opacity">
            Start Your Project
          </a>
          <a href="tel:0419400734" class="px-10 py-4 border border-parchment/15 text-parchment font-body text-sm tracking-wide rounded-full hover:border-accent hover:text-accent transition-colors">
            Call 0419 400 734
          </a>
        </div>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
