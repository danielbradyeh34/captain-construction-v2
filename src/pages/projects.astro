---
import BaseLayout from '../layouts/BaseLayout.astro';
import FadeIn from '../components/FadeIn';
import TextReveal from '../components/TextReveal';
import ProjectGrid from '../components/ProjectGrid';
---

<BaseLayout title="Projects" description="Explore our portfolio of new builds, extensions, decking and custom construction work across Geelong and the greater region." navVariant="dark">
  <!-- Hero -->
  <section class="relative bg-charcoal pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
    <img src="/images/heroes/hero-commercial-dark.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-30" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-charcoal/50 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="max-w-3xl">
        <FadeIn client:load direction="none">
          <p class="font-body text-[11px] tracking-[0.3em] text-brass uppercase mb-4">Portfolio</p>
        </FadeIn>
        <TextReveal client:load delay={0.2}>
          <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl text-cream tracking-tight">Our Projects</h1>
        </TextReveal>
        <FadeIn client:load delay={0.5} direction="up">
          <p class="text-cream/45 text-lg max-w-lg mt-6">
            From new homes to custom decking, every project is built with the same commitment to quality craftsmanship.
          </p>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="py-24 md:py-32 bg-graphite noise-overlay">
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <FadeIn client:load>
        <ProjectGrid client:load />
      </FadeIn>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 md:py-40 gradient-dark noise-overlay">
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <h2 class="font-heading text-4xl md:text-7xl text-cream tracking-tight mb-6">
          Like what you see?
        </h2>
        <p class="text-cream/40 text-lg mb-10 max-w-xl mx-auto">
          Let's discuss how we can bring the same level of craftsmanship to your project.
        </p>
        <a href="/contact" class="inline-block px-10 py-4 bg-brass text-warm-white font-body text-sm tracking-wide rounded-full hover:bg-brass-light transition-colors duration-300">
          Start Your Project
        </a>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
