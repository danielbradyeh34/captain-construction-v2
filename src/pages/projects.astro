---
import BaseLayout from '../layouts/BaseLayout.astro';
import FadeIn from '../components/FadeIn';
import ProjectGrid from '../components/ProjectGrid';
---

<BaseLayout title="Projects" description="Explore our portfolio of new builds, extensions, decking and custom construction work across Geelong and the greater region." navVariant="dark">
  <!-- Hero -->
  <section class="bg-charcoal pt-32 pb-20 md:pt-40 md:pb-28">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <p class="font-heading text-xs tracking-[0.4em] text-brass uppercase mb-4">Portfolio</p>
        <h1 class="font-heading text-4xl md:text-6xl tracking-[0.05em] text-cream font-light mb-6">
          Our Projects
        </h1>
        <p class="text-cream/50 text-lg max-w-2xl mx-auto">
          From new homes to custom decking, every project is built with the same commitment to quality craftsmanship.
        </p>
      </FadeIn>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="py-24 md:py-32 bg-graphite">
    <div class="max-w-7xl mx-auto px-6">
      <FadeIn client:load>
        <ProjectGrid client:load />
      </FadeIn>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32 bg-charcoal">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <h2 class="font-heading text-3xl md:text-5xl tracking-[0.05em] text-cream font-light mb-6">
          Like What You See?
        </h2>
        <p class="text-cream/50 text-lg mb-10 max-w-xl mx-auto">
          Let's discuss how we can bring the same level of craftsmanship to your project.
        </p>
        <a
          href="/contact"
          class="inline-block px-10 py-4 bg-brass text-warm-white font-heading text-sm tracking-[0.2em] uppercase hover:bg-brass-light transition-colors duration-300"
        >
          Start Your Project
        </a>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
