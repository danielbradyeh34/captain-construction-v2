---
import BaseLayout from '../layouts/BaseLayout.astro';
import FadeIn from '../components/FadeIn';
import ProcessTimeline from '../components/ProcessTimeline';
---

<BaseLayout title="Our Process" description="Learn how Captain Construction Co. delivers your project — from initial consultation to handover." navVariant="dark">
  <!-- Hero -->
  <section class="relative bg-dark pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
    <img src="/images/heroes/hero-framing.jpg" alt="" loading="eager" class="absolute inset-0 w-full h-full object-cover opacity-30" />
    <div class="absolute inset-0 bg-gradient-to-t from-dark/90 via-dark/50 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="max-w-3xl">
        <FadeIn client:load>
          <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">How We Work</p>
          <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl text-parchment tracking-tight">Our Process</h1>
          <p class="text-parchment/45 text-lg max-w-lg mt-6">
            Building a home is one of the biggest decisions you'll make. Our process is designed to make it seamless, transparent, and enjoyable.
          </p>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-24 md:py-36 bg-parchment">
    <div class="max-w-7xl mx-auto px-6">
      <ProcessTimeline client:load variant="light" />
    </div>
  </section>

  <!-- Promise -->
  <section class="py-24 md:py-36 bg-stone">
    <div class="max-w-5xl mx-auto px-6">
      <FadeIn client:load>
        <div class="text-center mb-16">
          <p class="font-body text-[11px] tracking-[0.3em] text-accent uppercase mb-4">Our Promise</p>
          <h2 class="font-heading text-4xl md:text-6xl text-dark tracking-tight">What you can expect</h2>
        </div>
      </FadeIn>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {[
          { title: 'Fixed Price Quotes', desc: 'No hidden costs. No budget blowouts. The price we quote is the price you pay, barring any changes you request.' },
          { title: 'Regular Updates', desc: "Weekly progress reports and photos. You always know exactly where your build is at without having to chase us." },
          { title: 'Clean Job Sites', desc: "We leave your property tidy at the end of every day. It sounds basic, but you'd be surprised how many builders don't." },
          { title: 'Warranty & Support', desc: 'Full structural warranty and ongoing support after handover. We stand behind our work — always.' },
        ].map((item, i) => (
          <FadeIn client:load delay={i * 0.08}>
            <div class="p-8 md:p-10 bg-parchment border border-border">
              <h3 class="font-body text-xs font-medium tracking-[0.15em] text-dark uppercase mb-3">{item.title}</h3>
              <p class="text-muted text-sm leading-relaxed">{item.desc}</p>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 md:py-44 bg-dark border-t border-parchment/5">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <h2 class="font-heading text-4xl md:text-7xl text-parchment tracking-tight mb-6">
          Ready to <em class="text-accent">get started?</em>
        </h2>
        <p class="text-parchment/40 text-lg mb-10 max-w-xl mx-auto">
          The first step is always a conversation. Tell us about your project and we'll take it from there.
        </p>
        <a href="/contact" class="inline-block px-10 py-4 bg-accent text-parchment font-body text-sm tracking-wide rounded-full hover:opacity-90 transition-opacity">
          Book a Consultation
        </a>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
