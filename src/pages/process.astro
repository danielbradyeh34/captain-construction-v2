---
import BaseLayout from '../layouts/BaseLayout.astro';
import FadeIn from '../components/FadeIn';
import ProcessTimeline from '../components/ProcessTimeline';
---

<BaseLayout title="Our Process" description="Learn how Captain Construction Co. delivers your project — from initial consultation to handover. Transparent, organised, and stress-free." navVariant="dark">
  <!-- Hero -->
  <section class="relative bg-charcoal pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
    <img src="/images/heroes/hero-framing.jpg" alt="Roof framing in progress against blue sky" class="absolute inset-0 w-full h-full object-cover opacity-40" />
    <div class="absolute inset-0 bg-charcoal/50"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <p class="font-heading text-xs tracking-[0.4em] text-brass uppercase mb-4">How We Work</p>
        <h1 class="font-heading text-4xl md:text-6xl tracking-[0.05em] text-cream font-light mb-6">
          Our Process
        </h1>
        <p class="text-cream/50 text-lg max-w-2xl mx-auto">
          Building a home is one of the biggest decisions you'll make. Our process is designed to make it seamless, transparent, and — dare we say — enjoyable.
        </p>
      </FadeIn>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-24 md:py-32 bg-warm-white">
    <div class="max-w-7xl mx-auto px-6">
      <ProcessTimeline client:load variant="light" />
    </div>
  </section>

  <!-- Promise -->
  <section class="py-24 md:py-32 bg-stone-light">
    <div class="max-w-4xl mx-auto px-6">
      <FadeIn client:load>
        <div class="text-center">
          <p class="font-heading text-xs tracking-[0.4em] text-brass uppercase mb-4">Our Promise</p>
          <h2 class="font-heading text-3xl md:text-5xl tracking-[0.05em] text-charcoal font-light mb-8">What You Can Expect</h2>
        </div>
      </FadeIn>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-12">
        {[
          { title: 'Fixed Price Quotes', desc: 'No hidden costs. No budget blowouts. The price we quote is the price you pay, barring any changes you request.' },
          { title: 'Regular Updates', desc: 'Weekly progress reports and photos. You always know exactly where your build is at without having to chase us.' },
          { title: 'Clean Job Sites', desc: 'We leave your property tidy at the end of every day. It sounds basic, but you\'d be surprised how many builders don\'t.' },
          { title: 'Warranty & Support', desc: 'Full structural warranty and ongoing support after handover. We stand behind our work — always.' },
        ].map((item, i) => (
          <FadeIn client:load delay={i * 0.1} direction="up">
            <div class="p-8 md:p-10 bg-warm-white border border-border">
              <h3 class="font-heading text-sm tracking-[0.2em] text-charcoal uppercase mb-3">{item.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{item.desc}</p>
            </div>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32 bg-charcoal">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <h2 class="font-heading text-3xl md:text-6xl tracking-[0.05em] text-cream font-light mb-6">
          Ready to Get Started?
        </h2>
        <p class="text-cream/50 text-lg mb-10 max-w-xl mx-auto">
          The first step is always a conversation. Tell us about your project and we'll take it from there.
        </p>
        <a
          href="/contact"
          class="inline-block px-10 py-4 bg-brass text-warm-white font-heading text-sm tracking-[0.2em] uppercase hover:bg-brass-light transition-colors duration-300"
        >
          Book a Consultation
        </a>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
