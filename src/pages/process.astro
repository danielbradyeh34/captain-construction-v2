---
import BaseLayout from '../layouts/BaseLayout.astro';
import FadeIn from '../components/FadeIn';
import TextReveal from '../components/TextReveal';
import ProcessTimeline from '../components/ProcessTimeline';
import StaggerChildren, { StaggerItem } from '../components/StaggerChildren';
---

<BaseLayout title="Our Process" description="Learn how Captain Construction Co. delivers your project — from initial consultation to handover." navVariant="dark">
  <!-- Hero -->
  <section class="relative bg-charcoal pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
    <img src="/images/heroes/hero-framing.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-30" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-charcoal/50 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="max-w-3xl">
        <FadeIn client:load direction="none">
          <p class="font-body text-[11px] tracking-[0.3em] text-brass uppercase mb-4">How We Work</p>
        </FadeIn>
        <TextReveal client:load delay={0.2}>
          <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl text-cream tracking-tight">Our Process</h1>
        </TextReveal>
        <FadeIn client:load delay={0.5} direction="up">
          <p class="text-cream/45 text-lg max-w-lg mt-6">
            Building a home is one of the biggest decisions you'll make. Our process is designed to make it seamless, transparent, and enjoyable.
          </p>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-24 md:py-36 bg-warm-white">
    <div class="max-w-7xl mx-auto px-6">
      <ProcessTimeline client:load variant="light" />
    </div>
  </section>

  <!-- Promise -->
  <section class="py-24 md:py-36 gradient-warm noise-overlay">
    <div class="relative z-10 max-w-5xl mx-auto px-6">
      <FadeIn client:load>
        <div class="text-center mb-16">
          <p class="font-body text-[11px] tracking-[0.3em] text-brass uppercase mb-4">Our Promise</p>
          <h2 class="font-heading text-4xl md:text-6xl text-charcoal tracking-tight">What you can expect</h2>
        </div>
      </FadeIn>

      <StaggerChildren client:load className="grid grid-cols-1 md:grid-cols-2 gap-5" staggerDelay={0.1}>
        {[
          { title: 'Fixed Price Quotes', desc: 'No hidden costs. No budget blowouts. The price we quote is the price you pay, barring any changes you request.' },
          { title: 'Regular Updates', desc: "Weekly progress reports and photos. You always know exactly where your build is at without having to chase us." },
          { title: 'Clean Job Sites', desc: "We leave your property tidy at the end of every day. It sounds basic, but you'd be surprised how many builders don't." },
          { title: 'Warranty & Support', desc: 'Full structural warranty and ongoing support after handover. We stand behind our work — always.' },
        ].map((item) => (
          <StaggerItem client:load>
            <div class="p-8 md:p-10 bg-warm-white rounded-2xl border border-border">
              <h3 class="font-body text-xs font-medium tracking-[0.15em] text-charcoal uppercase mb-3">{item.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{item.desc}</p>
            </div>
          </StaggerItem>
        ))}
      </StaggerChildren>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-28 md:py-40 gradient-dark noise-overlay">
    <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
      <FadeIn client:load>
        <h2 class="font-heading text-4xl md:text-7xl text-cream tracking-tight mb-6">
          Ready to <span class="italic text-brass">get started?</span>
        </h2>
        <p class="text-cream/40 text-lg mb-10 max-w-xl mx-auto">
          The first step is always a conversation. Tell us about your project and we'll take it from there.
        </p>
        <a href="/contact" class="inline-block px-10 py-4 bg-brass text-warm-white font-body text-sm tracking-wide rounded-full hover:bg-brass-light transition-colors duration-300">
          Book a Consultation
        </a>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
