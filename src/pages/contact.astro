---
import BaseLayout from '../layouts/BaseLayout.astro';
import FadeIn from '../components/FadeIn';
import TextReveal from '../components/TextReveal';
import ContactForm from '../components/ContactForm';
---

<BaseLayout title="Contact" description="Get in touch with Captain Construction Co. for a free consultation on your building project." navVariant="dark">
  <!-- Hero -->
  <section class="relative bg-charcoal pt-32 pb-20 md:pt-44 md:pb-32 overflow-hidden">
    <img src="/images/heroes/hero-bathroom.jpg" alt="" class="absolute inset-0 w-full h-full object-cover opacity-30" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-charcoal/50 to-transparent"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6">
      <div class="max-w-3xl">
        <FadeIn client:load direction="none">
          <p class="font-body text-[11px] tracking-[0.3em] text-brass uppercase mb-4">Get In Touch</p>
        </FadeIn>
        <TextReveal client:load delay={0.2}>
          <h1 class="font-heading text-5xl md:text-7xl lg:text-8xl text-cream tracking-tight">Let's talk</h1>
        </TextReveal>
        <FadeIn client:load delay={0.5} direction="up">
          <p class="text-cream/45 text-lg max-w-lg mt-6">
            Ready to start your project? Have questions? Drop us a line or give Cal a call.
          </p>
        </FadeIn>
      </div>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-24 md:py-36 bg-warm-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">
        <div class="lg:col-span-3">
          <FadeIn client:load direction="left">
            <h2 class="font-heading text-3xl md:text-4xl text-charcoal tracking-tight mb-8">Send us a message</h2>
            <ContactForm client:load />
          </FadeIn>
        </div>

        <div class="lg:col-span-2">
          <FadeIn client:load direction="right" delay={0.2}>
            <div class="space-y-10">
              <div>
                <h3 class="font-body text-[11px] font-medium tracking-[0.2em] text-brass uppercase mb-4">Call Us</h3>
                <a href="tel:0419400734" class="text-2xl font-heading text-charcoal tracking-tight hover:text-brass transition-colors">
                  0419 400 734
                </a>
                <p class="text-text-muted text-sm mt-2">Monday – Friday, 7am – 5pm</p>
              </div>

              <div>
                <h3 class="font-body text-[11px] font-medium tracking-[0.2em] text-brass uppercase mb-4">Location</h3>
                <p class="text-text-secondary leading-relaxed">Geelong & Greater Region<br />Victoria, Australia</p>
              </div>

              <div>
                <h3 class="font-body text-[11px] font-medium tracking-[0.2em] text-brass uppercase mb-4">Service Areas</h3>
                <ul class="space-y-2">
                  {['Geelong', 'Bellarine Peninsula', 'Surf Coast', 'Golden Plains', 'Greater Region'].map((area) => (
                    <li class="text-text-secondary text-sm flex items-center gap-2">
                      <span class="w-1.5 h-1.5 bg-brass rounded-full flex-shrink-0"></span>
                      {area}
                    </li>
                  ))}
                </ul>
              </div>

              <div class="p-8 bg-stone-light rounded-2xl">
                <h3 class="font-body text-[11px] font-medium tracking-[0.2em] text-brass uppercase mb-4">Quick Response</h3>
                <p class="text-text-secondary text-sm leading-relaxed">
                  We aim to respond to all enquiries within 24 hours. For urgent matters, give us a call directly.
                </p>
              </div>
            </div>
          </FadeIn>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
